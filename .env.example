# ── Database (Neon.tech) ─────────────────────────────────────────────────────
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Iron Session ──────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET="your-32-character-minimum-secret-here"

# ── Admin credentials ────────────────────────────────────────────────────────
# Plain text for now — Commit 6 will hash this with bcrypt
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-before-deploying"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
